{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service",
    "description": "Citizen-facing catalog content for a Camunda process, joined by processDefinitionId"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "instructions": {
      "type": "richtext"
    },
    "whatYouNeed": {
      "type": "richtext"
    },
    "expectedDuration": {
      "type": "string"
    },
    "processDefinitionId": {
      "type": "string",
      "required": true,
      "unique": true
    }
  }
}
