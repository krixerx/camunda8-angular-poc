      "credentials": [
        {
          "type": "password",
          "value": "bart",
          "temporary": false
        }
      ],
      "realmRoles": ["applicant"]
    },
    {
      "username": "homer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Homer",
      "lastName": "Simpson",
      "email": "homer@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "homer",
          "temporary": false
        }
      ],
      "realmRoles": ["civil-servant"]
    }
  ],
  "clients": [
    {
      "clientId": "poc-frontend",
      "name": "Camunda 8 POC Angular SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:4200/*"],
      "webOrigins": ["+"],
