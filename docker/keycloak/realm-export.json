{
  "realm": "camunda-poc",
  "enabled": true,
  "displayName": "Camunda 8 POC",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "applicant",
        "description": "Citizen who submits applications (starts process instances)"
      },
      {
        "name": "civil-servant",
        "description": "Official who reviews submissions (completes user tasks)"
      }
    ]
  },
  "users": [
    {
      "username": "bart",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bart",
      "lastName": "Simpson",
